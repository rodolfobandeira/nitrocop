#!/usr/bin/env bash
# Kilo Cloud Agent setup for nitrocop cop-fix tasks.
# Called from Kilo startup commands: bash .kilocode/setup-script

exec > >(tee -a /tmp/setup.log) 2>&1
echo "=== Setup started at $(date) ==="

# Install C compiler only if missing (ruby-prism crate needs it)
if ! command -v cc &>/dev/null; then
  echo "--- Installing build tools ---"
  if command -v sudo &>/dev/null; then
    sudo apt-get update -qq && sudo apt-get install -y -qq build-essential
  else
    apt-get update -qq && apt-get install -y -qq build-essential
  fi
fi

# Install Rust only if missing
if ! command -v cargo &>/dev/null; then
  echo "--- Installing Rust ---"
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
[ -f "/root/.cargo/env" ] && . "/root/.cargo/env"

# Ensure submodules are checked out (needed for ruby-prism build)
if [ ! -d "vendor/rubocop/.git" ] && [ -f ".gitmodules" ]; then
  echo "--- Checking out submodules ---"
  git submodule update --init --recursive
fi

# Build
echo "--- Building ($(date)) ---"
cargo build 2>&1

# Remove files that would confuse the agent
rm -f CLAUDE.md AGENTS.md
rm -rf .agents/ .claude/ .devcontainer/ .github/ bench/ docs/ gem/ scripts/

echo "=== Setup complete at $(date) ==="
