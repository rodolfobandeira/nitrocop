{
  "name": "nitrocop",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
  ],
  "containerEnv": {
    "CARGO_TARGET_DIR": "target-linux",
    "CC": "clang",
    "COLORTERM": "truecolor",
    "TERM": "xterm-256color",
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:DEVCONTAINER_CLAUDE_CODE_OAUTH_TOKEN}",
  },
  "postCreateCommand": ".devcontainer/setup.sh",
  "postStartCommand": {
    "kap-setup": "/opt/kap/bin/kap-post-start"
  },
  "remoteUser": "vscode",
  "dockerComposeFile": ["docker-compose.yml", "docker-compose.kap.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteEnv": {
    "PATH": "/opt/kap/bin:${containerEnv:PATH}"
  },
  "initializeCommand": "kap sidecar-init",
}
